  "helpersModulePath": "/Users/linxuan/Desktop/claude_code_research/claude-code/.claude/skills/polymarket-strategy/helpers.ts",
  "code": "\nconst closes = ctx.underlying.klines.map((k) => k.close);\nconst rsiVal = ctx.helpers.rsi(closes, 14);\nconst emaFast = ctx.helpers.emaArray(closes, 8).at(-1);\nconst emaSlow = ctx.helpers.emaArray(closes, 21).at(-1);\nconst emaTrend = emaFast > emaSlow ? 1 : -1; // +1 up, -1 down\n\nreturn ctx.markets.map((market) => {\n  const mCtx = { market, underlying: ctx.underlying, timing: { ...ctx.timing, expiryTs: market.expiryTs } };\n\n  if (market.closed || market.hoursToExpiry < 0) {\n    return { question: market.question, questionType: market.questionType, side: \"hold\", reason: \"market closed or expired\" };\n  }\n\n  try {\n    let base;\n    switch (market.questionType) {\n      case \"above\":\n        base = ctx.helpers.binaryProbsFromYesProb(mCtx, ctx.helpers.bsAbove(mCtx));\n        break;\n      case \"below\":\n        base = ctx.helpers.binaryProbsFromYesProb(mCtx, 1 - ctx.helpers.bsAbove(mCtx));\n        break;\n      case \"range\":\n        base = ctx.helpers.binaryProbsFromYesProb(mCtx, ctx.helpers.bsRange(mCtx));\n        break;\n      case \"hit\":\n        base = ctx.helpers.binaryProbsFromYesProb(mCtx, ctx.helpers.bsOneTouch(mCtx));\n        break;\n      case \"directional\": {\n        const basePUp = ctx.helpers.directionalProbUp(mCtx);\n        const imbalance = ctx.helpers.orderbookImbalance(mCtx);\n        // RSI: >55 bullish, <45 bearish\n        const rsiBias = rsiVal > 55 ? 0.04 : rsiVal < 45 ? -0.04 : 0;\n        // EMA trend\n        const emaBias = emaTrend * 0.03;\n        // Orderbook imbalance on Up side\n        const obBias = imbalance[0] * 0.15;\n        const adjPUp = Math.max(0.01, Math.min(0.99, basePUp + rsiBias + emaBias + obBias));\n        base = ctx.helpers.binaryProbsFromYesProb(mCtx, adjPUp);\n        break;\n      }\n      case \"firstHit\":\n        base = ctx.helpers.firstHitProbabilities(mCtx);\n        break;\n      default:\n        return { question: market.question, questionType: market.questionType, side: \"hold\", reason: `unsupported questionType: ${market.questionType}` };\n    }\n\n    const probs = ctx.helpers.normalizeBinaryProbabilities(base);\n    const trade = ctx.helpers.bestBinaryTrade(probs, mCtx, { threshold: 0.05 });\n\n    return {\n      question: market.question,\n      questionType: market.questionType,\n      strike: market.strike,\n      strike2: market.strike2,\n      expiryTs: market.expiryTs,\n      hoursToExpiry: market.hoursToExpiry,\n      probs,\n      outcomes: market.outcomes,\n      rsiVal,\n      emaTrend,\n      ...trade,\n    };\n  } catch (err) {\n    return { question: market.question, questionType: market.questionType, side: \"hold\", reason: String(err) };\n  }\n});\n",
