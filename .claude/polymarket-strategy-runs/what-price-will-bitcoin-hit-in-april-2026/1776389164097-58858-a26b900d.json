  "code": "\nconst et = ctx.helpers.eventPrimaryQuestionType(ctx);\nif (et === null) throw new Error(\"mixed-type event\");\n\n// Event-scope features (computed once)\nconst closes = ctx.underlying.klines.map((k) => k.close);\nconst rsi = ctx.helpers.rsi(closes, 14);\nconst emaFast = ctx.helpers.emaArray(closes, 12).at(-1);\nconst emaSlow = ctx.helpers.emaArray(closes, 26).at(-1);\nconst momentum = (emaFast - emaSlow) / emaSlow; // normalized momentum\n\nconst logit   = (p) => Math.log(p / (1 - p));\nconst sigmoid = (x) => 1 / (1 + Math.exp(-x));\nconst clamp   = (p) => Math.min(Math.max(p, 1e-6), 1 - 1e-6);\n\nconst THRESHOLD = 0.04;\n\nreturn ctx.markets.map((market) => {\n  try {\n    if (market.closed || market.hoursToExpiry < 0) {\n      return { question: market.question, questionType: market.questionType, decision: \"hold\", reason: \"closed or expired\" };\n    }\n    const mCtx = { market, underlying: ctx.underlying, timing: ctx.timing };\n\n    let pYes;\n    if (et === \"hit\") {\n      pYes = ctx.helpers.bsOneTouch(mCtx);\n    } else if (et === \"above\") {\n      pYes = ctx.helpers.bsAbove(mCtx);\n    } else if (et === \"below\") {\n      pYes = 1 - ctx.helpers.bsAbove(mCtx);\n    } else if (et === \"range\") {\n      pYes = ctx.helpers.bsRange(mCtx);\n    } else {\n      return { question: market.question, questionType: et, decision: \"hold\", reason: `unsupported type: ${et}` };\n    }\n\n    // Log-odds adjustment: RSI deviation + EMA momentum\n    const rsiShift  = (rsi - 50) / 100 * 0.3;\n    const momShift  = momentum * 0.5;\n    const distPct   = ctx.helpers.distanceToStrike(mCtx); // (strike - spot) / spot\n\n    // For \"hit\" markets: positive momentum + strike above spot → bullish boost\n    // For \"hit\" markets: strike below spot → already likely hit, no extra boost needed\n    const dirShift = et === \"hit\"\n      ? (distPct > 0 ? momShift + rsiShift : -rsiShift * 0.5)\n      : (rsiShift + momShift * 0.3);\n\n    const pYesAdj = sigmoid(logit(clamp(pYes)) + dirShift);\n    const probs   = ctx.helpers.binaryProbsFromYesProb(mCtx, pYesAdj);\n    const edges   = ctx.helpers.edgeFromProbs(probs, mCtx);\n    const best    = edges[0].edge >= edges[1].edge ? edges[0] : edges[1];\n\n    return {\n      question:     market.question,\n      questionType: market.questionType,\n      expiryDate:   market.expiryDate,\n      strike:       market.strike,\n      distancePct:  (distPct * 100).toFixed(2) + \"%\",\n      bsProb:       pYes.toFixed(4),\n      modelProb:    pYesAdj.toFixed(4),\n      probs,\n      decision:     best.edge >= THRESHOLD ? \"buy\" : \"hold\",\n      side:         best.edge >= THRESHOLD ? best.label : undefined,\n      fairPrice:    best.fairPrice,\n      marketPrice:  best.marketPrice,\n      edge:         best.edge,\n      volume:       market.volume,\n      liquidity:    market.liquidity,\n    };\n  } catch (err) {\n    return { question: market.question, decision: \"hold\", reason: String(err) };\n  }\n});\n",
