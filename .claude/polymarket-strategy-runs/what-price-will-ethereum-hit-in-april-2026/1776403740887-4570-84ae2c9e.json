  "code": "\n// =====================\n// Thresholds & weights\n// =====================\nconst EDGE_THRESHOLD      = 0.04;\nconst MOMENTUM_WEIGHT     = 0.30; // log-odds shift scale for momentum\nconst RSI_NEUTRAL         = 50;\nconst RSI_NORM_RANGE      = 20;   // ±20 from neutral → ±1\nconst RANDOM_SEED         = 42;\n\nconst logit   = (p) => Math.log(p / (1 - p));\nconst sigmoid = (x) => 1 / (1 + Math.exp(-x));\nconst clamp   = (v, lo, hi) => Math.max(lo, Math.min(hi, v));\n\n// =====================\n// Event-scope features (computed once)\n// =====================\nconst klines = ctx.underlying.klines;\nconst closes  = klines.map(k => k.close);\nconst highs   = klines.map(k => k.high);\nconst lows    = klines.map(k => k.low);\nconst n       = closes.length;\n\n// RSI(14)\nconst rsiVal    = ctx.helpers.rsi(closes, 14);\nconst rsiSignal = clamp((rsiVal - RSI_NEUTRAL) / RSI_NORM_RANGE, -1, 1);\n\n// EMA(12) / EMA(26) cross\nconst ema12     = ctx.helpers.emaArray(closes, 12).at(-1);\nconst ema26     = ctx.helpers.emaArray(closes, 26).at(-1);\nconst emaCross  = ema12 - ema26;\nconst emaSignal = emaCross > 0 ? 1 : -1;\n\n// MACD histogram\nconst ema12Arr  = ctx.helpers.emaArray(closes, 12);\nconst ema26Arr  = ctx.helpers.emaArray(closes, 26);\nconst macdLine  = ema12Arr.map((v, i) => v - ema26Arr[i]);\nconst signalArr = ctx.helpers.emaArray(macdLine, 9);\nconst macdHist  = macdLine.at(-1) - signalArr.at(-1);\nconst macdSignal = clamp(macdHist / closes[n-1] / 0.01, -1, 1); // normalize by ~1% price\n\n// Short-term momentum (1h return)\nconst ret1h        = n >= 2 ? (closes[n-1] - closes[n-2]) / closes[n-2] : 0;\nconst momentumSignal = clamp(ret1h / 0.02, -1, 1); // normalize by 2% move\n\n// ATR(14) / price — vol regime (confidence weight)\nlet atr = 0;\nif (n >= 15) {\n  const trs = [];\n  for (let i = 1; i < n; i++) {\n    const tr = Math.max(highs[i]-lows[i], Math.abs(highs[i]-closes[i-1]), Math.abs(lows[i]-closes[i-1]));\n    trs.push(tr);\n  }\n  let atrVal = trs.slice(0, 14).reduce((a, b) => a + b, 0) / 14;\n  for (let i = 14; i < trs.length; i++) atrVal = (atrVal * 13 + trs[i]) / 14;\n  atr = atrVal;\n}\nconst atrRatio = closes[n-1] > 0 ? atr / closes[n-1] : 0.02;\n\n// Composite momentum signal → log-odds shift\n// Higher ATR = higher vol = momentum signal gets wider confidence\nconst compositeSignal = (rsiSignal * 0.25 + emaSignal * 0.25 + macdSignal * 0.25 + momentumSignal * 0.25);\nconst logOddsShift    = compositeSignal * MOMENTUM_WEIGHT;\n\n// =====================\n// Market-type detection\n// =====================\nconst et = ctx.helpers.eventPrimaryQuestionType(ctx);\n\n// =====================\n// Per-market output\n// =====================\nreturn ctx.markets.map(market => {\n  try {\n    if (market.closed || market.hoursToExpiry < 0) {\n      return { question: market.question, decision: \"hold\", reason: \"closed or expired\" };\n    }\n\n    const mCtx = { market, underlying: ctx.underlying, timing: ctx.timing };\n    let probs;\n\n    // firstHit: returns aligned [p0, p1] from Monte Carlo — special case\n    if (market.questionType === \"firstHit\") {\n      const baseProbs = ctx.helpers.firstHitProbabilities(mCtx, { seed: RANDOM_SEED });\n      // Adjust p0 (first outcome) in log-odds; p1 = 1 - p0adj (valid simplex)\n      const p0 = clamp(baseProbs[0], 1e-6, 1 - 1e-6);\n      const p0adj = sigmoid(logit(p0) + logOddsShift);\n      probs = [p0adj, 1 - p0adj];\n    } else {\n      // Scalar yes-prob types: above / below / hit / range\n      let pYes;\n      switch (market.questionType) {\n        case \"above\": pYes = ctx.helpers.bsAbove(mCtx); break;\n        case \"below\": pYes = 1 - ctx.helpers.bsAbove(mCtx); break;\n        case \"hit\":   pYes = ctx.helpers.bsOneTouch(mCtx); break;\n        case \"range\": pYes = ctx.helpers.bsRange(mCtx); break;\n        default:\n          return { question: market.question, decision: \"hold\", reason: `unsupported type: ${market.questionType}` };\n      }\n      pYes = sigmoid(logit(clamp(pYes, 1e-6, 1 - 1e-6)) + logOddsShift);\n      probs = ctx.helpers.binaryProbsFromYesProb(mCtx, pYes);\n    }\n\n    const edges  = ctx.helpers.edgeFromProbs(probs, mCtx);\n    const best   = edges[0].edge >= edges[1].edge ? edges[0] : edges[1];\n    const worst  = edges[0].edge < edges[1].edge ? edges[0] : edges[1];\n\n    if (best.edge < EDGE_THRESHOLD) {\n      return {\n        question:      market.question,\n        questionType:  market.questionType,\n        decision:      \"hold\",\n        edge:          best.edge,\n        probs,\n        edges,\n        hoursToExpiry: market.hoursToExpiry,\n      };\n    }\n\n    return {\n      question:      market.question,\n      questionType:  market.questionType,\n      decision:      \"buy\",\n      side:          best.label,\n      fairPrice:     best.fairPrice,\n      marketPrice:   best.marketPrice,\n      edge:          best.edge,\n      probs,\n      edges,\n      hoursToExpiry: market.hoursToExpiry,\n      indicators: {\n        spotPrice:    closes[n-1],\n        atrRatio,\n        rsi14:        rsiVal,\n        ema12, ema26,\n        emaCross,\n        macdHist,\n        ret1h,\n        rsiSignal, emaSignal, macdSignal, momentumSignal,\n        compositeSignal,\n        logOddsShift,\n      },\n    };\n  } catch (err) {\n    return { question: market.question, decision: \"hold\", reason: String(err) };\n  }\n});\n",
